#include <cstdio>
#include <cmath>

#include <opencog/atoms/base/Atom.h>
#include <opencog/atoms/base/Link.h>
#include <opencog/atoms/base/Node.h>
#include <opencog/atoms/atom_types/atom_types.h>
#include <opencog/atoms/value/FloatValue.h>
#include <opencog/atoms/value/VoidValue.h>
#include <opencog/atomspace/AtomSpace.h>
#include <opencog/persist/gpu/GpuStorageNode.h>
#include <opencog/persist/gpu-types/atom_types.h>

#include <opencog/util/Logger.h>

#include <cxxtest/TestSuite.h>

using namespace opencog;

// ============================================================
// Compare two atoms for equality (type, name, truth value)

static void atomCompare(Handle a, Handle b, const char* where)
{
    printf("Testing at %s\n", where);
    TSM_ASSERT("No atom found", b != nullptr);
    if (nullptr == b) return;

    TSM_ASSERT_EQUALS("Type mismatch", a->get_type(), b->get_type());

    NodePtr na(NodeCast(a));
    NodePtr nb(NodeCast(b));
    if (na and nb)
    {
        TSM_ASSERT_EQUALS("Name mismatch", na->get_name(), nb->get_name());
    }

    LinkPtr la(LinkCast(a));
    LinkPtr lb(LinkCast(b));
    if (la and lb)
    {
        TSM_ASSERT_EQUALS("Arity mismatch", la->get_arity(), lb->get_arity());
    }

    ValuePtr ta = a->getValue(truth_key());
    ValuePtr tb = b->getValue(truth_key());
    if (ta or tb)
    {
        TSM_ASSERT("Missing truth value on a", ta);
        TSM_ASSERT("Missing truth value on b", tb);
        if (ta and tb)
        {
            TSM_ASSERT("Truth value miscompare", (*ta) == (*tb));

            if (not ((*ta) == (*tb)))
            {
                FloatValuePtr fva = FloatValueCast(ta);
                FloatValuePtr fvb = FloatValueCast(tb);
                if (fva and fvb)
                {
                    fprintf(stderr,
                        "Error at %s: val[0] a=%g b=%g, val[1] a=%g b=%g\n",
                        where,
                        fva->value()[0], fvb->value()[0],
                        fva->value().size() > 1 ? fva->value()[1] : -999.0,
                        fvb->value().size() > 1 ? fvb->value()[1] : -999.0);
                }
            }
        }
    }
}

// ============================================================

class GpuStorageNodeUTest : public CxxTest::TestSuite
{
private:
    std::string uri;

public:
    GpuStorageNodeUTest(void)
    {
        logger().set_level(Logger::INFO);
        logger().set_print_to_stdout_flag(true);
        logger().set_sync_flag(true);

        // Use first available GPU device
        uri = "gpu://:";
    }

    ~GpuStorageNodeUTest() {}

    void setUp(void) {}
    void tearDown(void) {}

    void test_open_close(void);
    void test_single_node(void);
    void test_node_with_value(void);
    void test_link_round_trip(void);
    void test_value_round_trip(void);
    void test_multiple_nodes(void);
    void test_erase(void);
    void test_monitor(void);
};

// ============================================================
// Test 1: Can we open and close a connection?

void GpuStorageNodeUTest::test_open_close(void)
{
    logger().info("BEGIN TEST: %s", __FUNCTION__);

    AtomSpacePtr as = createAtomSpace();
    Handle hsn = as->add_node(GPU_STORAGE_NODE, std::string(uri));
    GpuStorageNodePtr store = GpuStorageNodeCast(hsn);

    TSM_ASSERT("Failed to create GpuStorageNode", store != nullptr);
    TSM_ASSERT("Should not be connected yet", !store->connected());

    store->open();
    TSM_ASSERT("Should be connected after open", store->connected());

    store->close();
    TSM_ASSERT("Should not be connected after close", !store->connected());

    logger().info("END TEST: %s", __FUNCTION__);
}

// ============================================================
// Test 2: Store and fetch a single node (no values)

void GpuStorageNodeUTest::test_single_node(void)
{
    logger().info("BEGIN TEST: %s", __FUNCTION__);

    AtomSpacePtr as = createAtomSpace();
    Handle hsn = as->add_node(GPU_STORAGE_NODE, std::string(uri));
    GpuStorageNodePtr store = GpuStorageNodeCast(hsn);
    store->open();

    // Create a node
    Handle a(createNode(SCHEMA_NODE, "someNode"));

    // Store it
    store->storeAtom(a, true);
    store->barrier();
    printf("Stored single node\n");

    // Create a fresh handle with the same name and fetch
    Handle b(createNode(SCHEMA_NODE, "someNode"));
    store->getAtom(b);
    printf("Fetched single node\n");

    // Verify type and name match
    TSM_ASSERT_EQUALS("Type mismatch", a->get_type(), b->get_type());
    NodePtr na(NodeCast(a));
    NodePtr nb(NodeCast(b));
    TSM_ASSERT("Should be nodes", na and nb);
    if (na and nb)
        TSM_ASSERT_EQUALS("Name mismatch", na->get_name(), nb->get_name());

    store->erase();
    store->close();

    logger().info("END TEST: %s", __FUNCTION__);
}

// ============================================================
// Test 3: Store a node with a FloatValue, fetch it back

void GpuStorageNodeUTest::test_node_with_value(void)
{
    logger().info("BEGIN TEST: %s", __FUNCTION__);

    AtomSpacePtr as = createAtomSpace();
    Handle hsn = as->add_node(GPU_STORAGE_NODE, std::string(uri));
    GpuStorageNodePtr store = GpuStorageNodeCast(hsn);
    store->open();

    // Create a node with a truth value
    Handle a(createNode(SCHEMA_NODE, "nodeWithValue"));
    ValuePtr stv(createFloatValue(std::vector<double>({0.55, 0.6})));
    a->setValue(truth_key(), stv);

    // Store
    store->storeAtom(a, true);
    store->barrier();
    printf("Stored node with value\n");

    // Fetch back
    Handle b(createNode(SCHEMA_NODE, "nodeWithValue"));
    store->getAtom(b);
    printf("Fetched node with value\n");

    // Compare
    atomCompare(a, b, "Node with FloatValue round-trip");

    store->erase();
    store->close();

    logger().info("END TEST: %s", __FUNCTION__);
}

// ============================================================
// Test 4: Store a binary link (two nodes), fetch it back

void GpuStorageNodeUTest::test_link_round_trip(void)
{
    logger().info("BEGIN TEST: %s", __FUNCTION__);

    AtomSpacePtr as = createAtomSpace();
    Handle hsn = as->add_node(GPU_STORAGE_NODE, std::string(uri));
    GpuStorageNodePtr store = GpuStorageNodeCast(hsn);
    store->open();

    // Create two nodes and a link with a value
    Handle n1(createNode(SCHEMA_NODE, "wordA"));
    Handle n2(createNode(SCHEMA_NODE, "wordB"));

    HandleSeq hvec;
    hvec.push_back(n1);
    hvec.push_back(n2);
    Handle lnk(createLink(hvec, LIST_LINK));
    ValuePtr stv(createFloatValue(std::vector<double>({12.5, 3.7})));
    lnk->setValue(truth_key(), stv);

    // Store
    store->storeAtom(lnk, true);
    store->barrier();
    printf("Stored link with value\n");

    // Fetch back -- create fresh link with same structure
    Handle fn1(createNode(SCHEMA_NODE, "wordA"));
    Handle fn2(createNode(SCHEMA_NODE, "wordB"));
    Handle flnk(createLink(LIST_LINK, fn1, fn2));
    store->getAtom(flnk);
    printf("Fetched link with value\n");

    // Compare the truth value
    atomCompare(lnk, flnk, "Link round-trip");

    store->erase();
    store->close();

    logger().info("END TEST: %s", __FUNCTION__);
}

// ============================================================
// Test 5: storeValue / loadValue specific key

void GpuStorageNodeUTest::test_value_round_trip(void)
{
    logger().info("BEGIN TEST: %s", __FUNCTION__);

    AtomSpacePtr as = createAtomSpace();
    Handle hsn = as->add_node(GPU_STORAGE_NODE, std::string(uri));
    GpuStorageNodePtr store = GpuStorageNodeCast(hsn);
    store->open();

    // Create a node with truth value
    Handle a(createNode(SCHEMA_NODE, "valueTestNode"));
    double v1 = 1.0e33 / 3.0;
    double v2 = 1.0e-30 / 300.0;
    ValuePtr stv(createFloatValue(std::vector<double>({v1, v2})));
    a->setValue(truth_key(), stv);

    // Store just the value
    store->storeValue(a, truth_key());
    store->barrier();
    printf("Stored value\n");

    // Create a fresh atom and load just the value
    Handle b(createNode(SCHEMA_NODE, "valueTestNode"));
    store->loadValue(b, truth_key());
    printf("Loaded value\n");

    // Compare
    atomCompare(a, b, "Value round-trip with extreme floats");

    // Verify the actual doubles match
    FloatValuePtr fva = FloatValueCast(a->getValue(truth_key()));
    FloatValuePtr fvb = FloatValueCast(b->getValue(truth_key()));
    TSM_ASSERT("Missing value on a", fva);
    TSM_ASSERT("Missing value on b", fvb);
    if (fva and fvb)
    {
        TSM_ASSERT_EQUALS("Value size mismatch",
            fva->value().size(), fvb->value().size());
        for (size_t i = 0; i < fva->value().size(); i++)
        {
            TSM_ASSERT_DELTA("Float value mismatch",
                fva->value()[i], fvb->value()[i], 1e-10 * fabs(fva->value()[i]));
        }
    }

    store->erase();
    store->close();

    logger().info("END TEST: %s", __FUNCTION__);
}

// ============================================================
// Test 6: Store many nodes, verify pool counts

void GpuStorageNodeUTest::test_multiple_nodes(void)
{
    logger().info("BEGIN TEST: %s", __FUNCTION__);

    AtomSpacePtr as = createAtomSpace();
    Handle hsn = as->add_node(GPU_STORAGE_NODE, std::string(uri));
    GpuStorageNodePtr store = GpuStorageNodeCast(hsn);
    store->open();

    const int N = 100;

    // Store N nodes
    for (int i = 0; i < N; i++)
    {
        std::string name = "testWord_" + std::to_string(i);
        Handle h(createNode(SCHEMA_NODE, name));
        double count = (double)(i + 1);
        double mi = count * 0.1;
        h->setValue(truth_key(),
            createFloatValue(std::vector<double>({count, mi})));
        store->storeAtom(h, false);
    }
    store->barrier();
    printf("Stored %d nodes\n", N);

    // Fetch them all back and verify
    int found = 0;
    for (int i = 0; i < N; i++)
    {
        std::string name = "testWord_" + std::to_string(i);
        Handle h(createNode(SCHEMA_NODE, name));
        store->getAtom(h);

        ValuePtr tv = h->getValue(truth_key());
        if (tv)
        {
            FloatValuePtr fv = FloatValueCast(tv);
            if (fv and fv->value().size() >= 2)
            {
                double expected_count = (double)(i + 1);
                double expected_mi = expected_count * 0.1;
                TSM_ASSERT_DELTA("Count mismatch",
                    fv->value()[0], expected_count, 1e-10);
                TSM_ASSERT_DELTA("MI mismatch",
                    fv->value()[1], expected_mi, 1e-10);
                found++;
            }
        }
    }

    printf("Verified %d / %d nodes\n", found, N);
    TSM_ASSERT_EQUALS("Not all nodes found", found, N);

    store->erase();
    store->close();

    logger().info("END TEST: %s", __FUNCTION__);
}

// ============================================================
// Test 7: Erase clears everything

void GpuStorageNodeUTest::test_erase(void)
{
    logger().info("BEGIN TEST: %s", __FUNCTION__);

    AtomSpacePtr as = createAtomSpace();
    Handle hsn = as->add_node(GPU_STORAGE_NODE, std::string(uri));
    GpuStorageNodePtr store = GpuStorageNodeCast(hsn);
    store->open();

    // Store some data
    Handle a(createNode(SCHEMA_NODE, "eraseMe"));
    a->setValue(truth_key(),
        createFloatValue(std::vector<double>({42.0, 7.5})));
    store->storeAtom(a, true);
    store->barrier();

    // Erase
    store->erase();

    // Try to fetch -- should not find it
    Handle b(createNode(SCHEMA_NODE, "eraseMe"));
    store->getAtom(b);

    ValuePtr tv = b->getValue(truth_key());
    TSM_ASSERT("Should not have value after erase", nullptr == tv);

    store->close();

    logger().info("END TEST: %s", __FUNCTION__);
}

// ============================================================
// Test 8: Monitor returns useful info

void GpuStorageNodeUTest::test_monitor(void)
{
    logger().info("BEGIN TEST: %s", __FUNCTION__);

    AtomSpacePtr as = createAtomSpace();
    Handle hsn = as->add_node(GPU_STORAGE_NODE, std::string(uri));
    GpuStorageNodePtr store = GpuStorageNodeCast(hsn);
    store->open();

    // Store a node
    Handle a(createNode(SCHEMA_NODE, "monitorTest"));
    store->storeAtom(a, true);
    store->barrier();

    std::string stats = store->monitor();
    printf("Monitor output:\n%s\n", stats.c_str());

    TSM_ASSERT("Monitor should contain GPU", stats.find("gpu://") != std::string::npos);
    TSM_ASSERT("Monitor should show connected",
        stats.find("Connected: yes") != std::string::npos);
    TSM_ASSERT("Monitor should show word count",
        stats.find("Words:") != std::string::npos);

    store->erase();
    store->close();

    logger().info("END TEST: %s", __FUNCTION__);
}

